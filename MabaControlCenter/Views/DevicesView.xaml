<UserControl x:Class="MabaControlCenter.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}"
             Loaded="DevicesView_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" VerticalAlignment="Top">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding PlaceholderText}" FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_ComPort}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,12"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Ports}"
                          SelectedItem="{Binding SelectedPort, UpdateSourceTrigger=PropertyChanged}"
                          Margin="0,0,0,12" MinHeight="28"
                          Background="{DynamicResource BackgroundLightBrush}"
                          Foreground="{DynamicResource TextOnLightBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"/>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,12">
                    <Button Content="{Binding Source={StaticResource Labels}, Path=Button_Refresh}" Command="{Binding RefreshPortsCommand}"
                            Padding="12,8" Margin="0,0,8,0" MinWidth="70"
                            Background="{DynamicResource BackgroundLightBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                    <Button Content="{Binding Source={StaticResource Labels}, Path=Button_Connect}" Command="{Binding ConnectCommand}"
                            Padding="16,8" Margin="0,0,8,0" MinWidth="90"
                            Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button Content="{Binding Source={StaticResource Labels}, Path=Button_Disconnect}" Command="{Binding DisconnectCommand}"
                            Padding="16,8" MinWidth="90"
                            Background="{DynamicResource BackgroundLightBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_Status}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ConnectionStatus}"
                           VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>

            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_DeviceInfo}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,24,0,8"/>

            <!-- No device detected - help panel -->
            <Border Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="16" Margin="0,0,0,0"
                    Visibility="{Binding ShowNoDevicePanel, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Title}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Message}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Suggestion_USB}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Suggestion_Port}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Suggestion_Refresh}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Suggestion_Drivers}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Button_Drivers}"
                                Command="{Binding OpenUrlCommand}" CommandParameter="{Binding SoftwareUrlValue}"
                                Padding="12,8" Margin="0,0,8,0" MinWidth="100"
                                Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderThickness="0" Cursor="Hand"/>
                        <Button Content="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Button_Support}"
                                Command="{Binding OpenUrlCommand}" CommandParameter="{Binding SoftwareUrlValue}"
                                Padding="12,8" Margin="0,0,8,0" MinWidth="100"
                                Background="{DynamicResource BackgroundMediumBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                        <Button Content="{Binding Source={StaticResource Labels}, Path=Device_NoDevice_Button_Troubleshooting}"
                                Command="{Binding OpenUrlCommand}" CommandParameter="{Binding SoftwareUrlValue}"
                                Padding="12,8" MinWidth="120"
                                Background="{DynamicResource BackgroundMediumBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Unsupported device - warning panel -->
            <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="16" Margin="0,0,0,0"
                    Visibility="{Binding ShowUnsupportedPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Device_Unsupported_Title}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,12" Visibility="{Binding DeviceProfile.ProductName, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_ProductName}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.ProductName}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,16" Visibility="{Binding DeviceProfile.ConnectionType, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_ConnectionType}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.ConnectionType}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding Source={StaticResource Labels}, Path=Device_Unsupported_Button_RequestSupport}"
                                Command="{Binding OpenUrlCommand}" CommandParameter="{Binding WebsiteUrlValue}"
                                Padding="12,8" Margin="0,0,8,0" MinWidth="100"
                                Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderThickness="0" Cursor="Hand"/>
                        <Button Content="{Binding Source={StaticResource Labels}, Path=Device_Unsupported_Button_Website}"
                                Command="{Binding OpenUrlCommand}" CommandParameter="{Binding WebsiteUrlValue}"
                                Padding="12,8" MinWidth="100"
                                Background="{DynamicResource BackgroundLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Supported device - normal device info panel -->
            <Border Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="16" Margin="0,0,0,0"
                    Visibility="{Binding ShowSupportedPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_ProductName}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.ProductName}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_ProductCode}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.ProductCode}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_FirmwareVersion}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.FirmwareVersion}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_SerialNumber}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.SerialNumber}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_ConnectionType}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.ConnectionType}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_RecommendedModule}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.RecommendedModule}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_SupportStatus}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceProfile.SupportStatusDisplay}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

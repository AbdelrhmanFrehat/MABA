<Window x:Class="MabaControlCenter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MabaControlCenter.ViewModels"
        xmlns:views="clr-namespace:MabaControlCenter.Views"
        Title="{Binding Source={StaticResource Labels}, Path=App_Title}"
        Height="600" Width="1000"
        MinHeight="400" MinWidth="700"
        Background="{DynamicResource BackgroundDarkBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/MabaControlCenter;component/Assets/maba.ico">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiscoverViewModel}">
            <views:DiscoverView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DevicesViewModel}">
            <views:DevicesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:JobsViewModel}">
            <views:JobsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CommandsViewModel}">
            <views:CommandsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModulesViewModel}">
            <views:ModulesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DexterCalibrationViewModel}">
            <views:DexterCalibrationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductionWorkspaceViewModel}">
            <views:ProductionWorkspaceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,60,0,0">
                <Button Content="{Binding Source={StaticResource Labels}, Path=Sidebar_Dashboard}" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Sidebar_Discover}" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Discover"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Sidebar_Devices}" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Devices"/>
                <Button Content="Jobs" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Jobs"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Sidebar_Commands}" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Commands"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Sidebar_Modules}" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Modules"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Sidebar_Logs}" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Logs"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Sidebar_Settings}" Style="{DynamicResource SidebarNavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
            </StackPanel>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top header -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
                <TextBlock Text="{Binding Source={StaticResource Labels}, Path=App_Title}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </Border>

            <!-- Back to Modules bar: visible only on Dexter Calibration module -->
            <Border Grid.Row="1" Background="#1A2435" BorderBrush="#3D4A5A" BorderThickness="0,0,0,1" Padding="24,12,24,12"
                    Visibility="{Binding IsDexterCalibrationModule, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button Content="← Back to Modules" Command="{Binding NavigateCommand}" CommandParameter="Modules"
                        HorizontalAlignment="Left" Padding="14,10" MinHeight="40" MinWidth="180"
                        Background="#263548" Foreground="#94A3B8" BorderBrush="#3D4A5A" BorderThickness="1"
                        FontSize="14" Cursor="Hand"/>
            </Border>

            <!-- Page content -->
            <ContentControl Grid.Row="2" Content="{Binding CurrentViewModel}" Margin="24"
                            VerticalContentAlignment="Top" HorizontalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>

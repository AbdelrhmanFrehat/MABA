<UserControl x:Class="MabaControlCenter.Views.CncControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MabaControlCenter.Controls"
             Background="{DynamicResource BackgroundDarkBrush}">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="CncPanelSurfaceBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource BackgroundLight}" Offset="0"/>
            <GradientStop Color="{DynamicResource BackgroundMedium}" Offset="0.55"/>
            <GradientStop Color="{DynamicResource BackgroundDark}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CncPanelSurfaceHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource BackgroundLight}" Offset="0"/>
            <GradientStop Color="{DynamicResource BackgroundLight}" Offset="0.45"/>
            <GradientStop Color="{DynamicResource BackgroundMedium}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CncJogSurfaceBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource BackgroundLight}" Offset="0"/>
            <GradientStop Color="{DynamicResource BackgroundMedium}" Offset="0.5"/>
            <GradientStop Color="{DynamicResource BackgroundDark}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CncJogSurfaceHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource AccentHover}" Offset="0"/>
            <GradientStop Color="{DynamicResource BackgroundLight}" Offset="0.5"/>
            <GradientStop Color="{DynamicResource BackgroundMedium}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CncDangerSurfaceBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource ErrorHighlight}" Offset="0"/>
            <GradientStop Color="{DynamicResource BackgroundMedium}" Offset="0.5"/>
            <GradientStop Color="{DynamicResource BackgroundDark}" Offset="1"/>
        </LinearGradientBrush>

        <DataTemplate x:Key="MachineCategoryDisplayTemplate">
            <StackPanel>
                <TextBlock Text="{Binding DisplayNameEn}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Code}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="MachineFamilyDisplayTemplate">
            <StackPanel>
                <TextBlock Text="{Binding DisplayNameEn}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Manufacturer}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="MachineDefinitionDisplayTemplate">
            <StackPanel>
                <TextBlock Text="{Binding DisplayNameEn}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                    <Run Text="{Binding Code}"/>
                    <Run Text="  v"/>
                    <Run Text="{Binding Version}"/>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="RuntimeProfileDisplayTemplate">
            <StackPanel>
                <TextBlock Text="{Binding ProfileName}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                    <Run Text="{Binding ProfileType}"/>
                    <Run Text="  /  "/>
                    <Run Text="{Binding CompatibilityState}"/>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <DropShadowEffect x:Key="CncPanelGlowEffect" Color="#8858B7FF" BlurRadius="14" ShadowDepth="0" Opacity="0.32"/>
        <DropShadowEffect x:Key="CncPanelGlowHoverEffect" Color="#AA74D1FF" BlurRadius="18" ShadowDepth="0" Opacity="0.48"/>
        <DropShadowEffect x:Key="CncJogGlowEffect" Color="#AA6C84FF" BlurRadius="18" ShadowDepth="0" Opacity="0.52"/>
        <DropShadowEffect x:Key="CncDangerGlowEffect" Color="#99FF5B8C" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>

        <Style x:Key="CncPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CncPanelSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="124"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Border x:Name="OuterShell"
                                    Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Effect="{StaticResource CncPanelGlowEffect}"/>
                            <Border x:Name="OuterBevel"
                                    Margin="1"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"/>
                            <Border x:Name="InnerBody"
                                    Margin="4"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Border Height="11"
                                            VerticalAlignment="Top"
                                            CornerRadius="5,5,2,2"
                                            Margin="2,2,2,0"
                                            Background="#22FFFFFF"/>
                                    <Border Height="1"
                                            VerticalAlignment="Top"
                                            Margin="8,11,8,0"
                                            Background="#33DDEBFF"/>
                                    <ContentPresenter x:Name="contentPresenter"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.FontWeight="{TemplateBinding FontWeight}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Grid>
                            </Border>
                            <Border x:Name="PressedShade"
                                    Margin="4"
                                    CornerRadius="6"
                                    Background="#00000000"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterShell" Property="Effect" Value="{StaticResource CncPanelGlowHoverEffect}"/>
                                <Setter TargetName="OuterShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter TargetName="InnerBody" Property="Background" Value="{StaticResource CncPanelSurfaceHoverBrush}"/>
                                <Setter TargetName="InnerBody" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="InnerBody" Property="Margin" Value="5,5,4,3"/>
                                <Setter TargetName="PressedShade" Property="Background" Value="#22000000"/>
                                <Setter TargetName="InnerBody" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                <Setter TargetName="OuterShell" Property="Effect" Value="{StaticResource CncPanelGlowEffect}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterShell" Property="Opacity" Value="0.46"/>
                                <Setter TargetName="OuterShell" Property="Effect" Value="{x:Null}"/>
                                <Setter TargetName="OuterShell" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter TargetName="InnerBody" Property="Opacity" Value="0.55"/>
                                <Setter Property="Foreground" Value="#FF8A95A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CncDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource CncPrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource CncDangerSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Border x:Name="OuterShell"
                                    Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Effect="{StaticResource CncDangerGlowEffect}"/>
                            <Border x:Name="OuterBevel"
                                    Margin="1"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"/>
                            <Border x:Name="InnerBody"
                                    Margin="4"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Border Height="11"
                                            VerticalAlignment="Top"
                                            CornerRadius="5,5,2,2"
                                            Margin="2,2,2,0"
                                            Background="#18FFF0F5"/>
                                    <Border Height="1"
                                            VerticalAlignment="Top"
                                            Margin="8,11,8,0"
                                            Background="#44FF96B5"/>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.FontWeight="{TemplateBinding FontWeight}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Grid>
                            </Border>
                            <Border x:Name="PressedShade"
                                    Margin="4"
                                    CornerRadius="6"
                                    Background="#00000000"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter TargetName="InnerBody" Property="Background" Value="{DynamicResource ErrorHighlightBrush}"/>
                                <Setter TargetName="InnerBody" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="InnerBody" Property="Margin" Value="5,5,4,3"/>
                                <Setter TargetName="PressedShade" Property="Background" Value="#22000000"/>
                                <Setter TargetName="InnerBody" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterShell" Property="Opacity" Value="0.44"/>
                                <Setter TargetName="OuterShell" Property="Effect" Value="{x:Null}"/>
                                <Setter TargetName="InnerBody" Property="Opacity" Value="0.55"/>
                                <Setter Property="Foreground" Value="#FF8A95A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CncJogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CncJogSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="112"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Border x:Name="OuterShell"
                                    Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1.4"
                                    CornerRadius="16"
                                    Effect="{StaticResource CncJogGlowEffect}"/>
                            <Border x:Name="OuterRim"
                                    Margin="2"
                                    CornerRadius="14"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"/>
                            <Border x:Name="InnerBody"
                                    Margin="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11">
                                <Grid>
                                    <Border Margin="4,4,4,0"
                                            Height="14"
                                            VerticalAlignment="Top"
                                            CornerRadius="8,8,3,3"
                                            Background="#28FFFFFF"/>
                                    <Border Margin="8,20,8,0"
                                            Height="1"
                                            VerticalAlignment="Top"
                                            Background="#40D8F3FF"/>
                                    <Border Margin="8"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"/>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.FontWeight="{TemplateBinding FontWeight}"
                                                      TextElement.FontSize="{TemplateBinding FontSize}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Grid>
                            </Border>
                            <Border x:Name="PressedShade"
                                    Margin="6"
                                    CornerRadius="11"
                                    Background="#00000000"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter TargetName="InnerBody" Property="Background" Value="{StaticResource CncJogSurfaceHoverBrush}"/>
                                <Setter TargetName="InnerBody" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="InnerBody" Property="Margin" Value="7,8,5,4"/>
                                <Setter TargetName="InnerBody" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                <Setter TargetName="PressedShade" Property="Background" Value="#26000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterShell" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="OuterShell" Property="Effect" Value="{x:Null}"/>
                                <Setter TargetName="InnerBody" Property="Opacity" Value="0.5"/>
                                <Setter Property="Foreground" Value="#FF8892A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CncWorkspaceTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12,12,0,0"
                                    Padding="8,8,8,0">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Background="{DynamicResource BackgroundMediumBrush}"/>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="{DynamicResource BackgroundDarkBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1,0,1,1"
                                    CornerRadius="0,0,12,12"
                                    Padding="12">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectedContentStringFormat}"
                                                  Margin="{TemplateBinding Padding}"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CncWorkspaceTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabShell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10,10,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabShell" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter TargetName="TabShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabShell" Property="Background" Value="{DynamicResource BackgroundDarkBrush}"/>
                                <Setter TargetName="TabShell" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="Panel.ZIndex" Value="10"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabShell" Property="Opacity" Value="0.45"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputShell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="TopHighlight"
                                        Height="1"
                                        VerticalAlignment="Top"
                                        Margin="8,1,8,0"
                                        Background="#22FFFFFF"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputShell" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="InputShell" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#776366F1" BlurRadius="10" ShadowDepth="0" Opacity="0.32"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter TargetName="TopHighlight" Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.58"/>
                                <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter TargetName="InputShell" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemShell"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemShell" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemShell" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboShell"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="7">
                                            <Grid>
                                                <Border Height="1"
                                                        VerticalAlignment="Top"
                                                        Margin="8,1,28,0"
                                                        Background="#22FFFFFF"/>
                                                <Path x:Name="Arrow"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{DynamicResource TextSecondaryBrush}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboShell" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="ComboShell" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#776366F1" BlurRadius="10" ShadowDepth="0" Opacity="0.28"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ComboShell" Property="Opacity" Value="0.58"/>
                                                <Setter TargetName="Arrow" Property="Opacity" Value="0.55"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource BackgroundMediumBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="2">
                                    <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="64"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.58"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="{DynamicResource BackgroundMediumBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 3 9 L 7 13 L 15 4"
                                      Stroke="{DynamicResource TextPrimaryBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemShell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter TargetName="ItemShell" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemShell" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="ItemShell" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WizardStepPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Opacity" Value="0.78"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#776366F1" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WizardCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardShell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardShell" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter TargetName="CardShell" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter TargetName="CardShell" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#556366F1" BlurRadius="14" ShadowDepth="0" Opacity="0.28"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="CardShell" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="CardShell" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                <Setter TargetName="CardShell" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#886366F1" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardShell" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WizardStepPaneStyle" TargetType="Border">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.16"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 From="16"
                                                 To="0"
                                                 Duration="0:0:0.16"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{DynamicResource BackgroundDarkBrush}">
        <StackPanel Margin="24" VerticalAlignment="Top">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding Subtitle}" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20"/>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16"
                    Visibility="{Binding HasActiveJob, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Active Production Job" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ActiveJobTitle}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ActiveJobReference}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                    <Button Content="Back to Jobs"
                            Command="{Binding BackToJobsCommand}"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Border>

            <TabControl FlowDirection="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FlowDirection}"
                        Style="{StaticResource CncWorkspaceTabControlStyle}"
                        ItemContainerStyle="{StaticResource CncWorkspaceTabItemStyle}">
                <TabItem Header="{Binding Source={StaticResource Labels}, Path=Cnc_Tab_Operate}">
                    <StackPanel Margin="0,16,0,0">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="G-code Runner" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <WrapPanel Margin="0,0,0,12">
                        <Button Content="Load G-code"
                                Command="{Binding LoadGcodeCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,8"/>
                        <Button Content="Clear Loaded Job"
                                Command="{Binding ClearLoadedProgramCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,8"/>
                        <Button Content="Start"
                                Command="{Binding StartProgramCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,8"/>
                        <Button Content="Pause"
                                Command="{Binding PauseProgramCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,8"/>
                        <Button Content="Resume"
                                Command="{Binding ResumeProgramCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,8"/>
                        <Button Content="Stop"
                                Command="{Binding StopCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,8"/>
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Loaded File" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoadedFileName}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Job Title" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LoadedJobTitle}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Source Reference" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LoadedJobSourceReference}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Summary" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LoadedFileSummary}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Job Status" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding JobSessionStateDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Active Profile" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LoadedJobProfileName}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Driver Mode" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LoadedJobDriverMode}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Run Readiness" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding JobReadinessSummary}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    </Grid>
                    <TextBlock Text="{Binding JobBlockingReason}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasBlockingReason, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="0.95*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Connection" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding AvailablePorts}"
                                          SelectedItem="{Binding SelectedPort, UpdateSourceTrigger=PropertyChanged}"
                                          IsEnabled="{Binding IsHardwarePortRequired}"
                                          MinHeight="30"
                                          Margin="0,0,8,0"
                                          Background="{DynamicResource BackgroundLightBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          BorderBrush="{DynamicResource BorderBrush}"/>
                                <Button Grid.Column="1"
                                        Content="Refresh Ports"
                                        Command="{Binding RefreshPortsCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="2"
                                        Content="Connect"
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="3"
                                        Content="Disconnect"
                                        Command="{Binding DisconnectCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </Grid>
                            <TextBlock Text="{Binding ConnectionStatusText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding RuntimeModeText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ActiveProfileBaudRateDisplay, StringFormat=Baud rate: {0}}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Job Placement" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Offset X"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding PlacementOffsetX, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text=""
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="Offset Y"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="4"
                                         Text="{Binding PlacementOffsetY, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"/>
                            </Grid>

                            <WrapPanel Margin="0,0,0,12">
                                <Button Content="Apply"
                                        Command="{Binding ApplyPlacementCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Reset Placement"
                                        Command="{Binding ResetPlacementCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,12,8"/>
                                <Button Content="Top Left"
                                        Command="{Binding PlaceTopLeftCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Top Right"
                                        Command="{Binding PlaceTopRightCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Bottom Left"
                                        Command="{Binding PlaceBottomLeftCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Bottom Right"
                                        Command="{Binding PlaceBottomRightCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Center"
                                        Command="{Binding PlaceCenterCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                            </WrapPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Applied Offset"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6">
                                    <Run Text="{Binding AppliedPlacementOffsetX, Mode=OneWay, StringFormat={}{0:0.###} mm X}"/>
                                    <Run Text=" / "/>
                                    <Run Text="{Binding AppliedPlacementOffsetY, Mode=OneWay, StringFormat={}{0:0.###} mm Y}"/>
                                </TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Bounding Box"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6">
                                    <Run Text="{Binding FrameMinX, Mode=OneWay, StringFormat={}{0:0.###}}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding FrameMinY, Mode=OneWay, StringFormat={}{0:0.###}}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding FrameMaxX, Mode=OneWay, StringFormat={}{0:0.###}}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding FrameMaxY, Mode=OneWay, StringFormat={}{0:0.###}}"/>
                                    <Run Text=" mm"/>
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Placement Status"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding PlacementStatus}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="G-code Preview Simulation" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <WrapPanel Margin="0,0,0,12">
                                <Button Content="Frame"
                                        Command="{Binding FramePreviewCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Play"
                                        Command="{Binding PlayPreviewCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Pause"
                                        Command="{Binding PausePreviewCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button Content="Stop"
                                        Command="{Binding StopPreviewCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,12,8"/>
                                <StackPanel Margin="0,2,0,8">
                                    <TextBlock Text="Preview Speed"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Slider Width="150"
                                                Minimum="0.5"
                                                Maximum="4"
                                                TickFrequency="0.5"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding PreviewPlaybackSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="{Binding PreviewPlaybackSpeedDisplay}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </WrapPanel>

                            <controls:CncToolpathPreviewControl Height="280"
                                                                Motions="{Binding PreviewMotions}"
                                                                CurrentSegmentIndex="{Binding PreviewCurrentSegmentIndex}"
                                                                SegmentProgress="{Binding PreviewSegmentProgress}"
                                                                ToolX="{Binding PreviewToolX}"
                                                                ToolY="{Binding PreviewToolY}"
                                                                MachineWidth="{Binding XLimitMm}"
                                                                MachineHeight="{Binding YLimitMm}"/>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Preview State" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewSimulationStateDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Segment" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewCurrentLineText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Distance" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewTotalDistanceMm, Mode=OneWay, StringFormat={}{0:0.###} mm}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Cut / Rapid" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6">
                                    <Run Text="{Binding PreviewCutDistanceMm, Mode=OneWay, StringFormat={}{0:0.###} mm cut}"/>
                                    <Run Text=" / "/>
                                    <Run Text="{Binding PreviewRapidDistanceMm, Mode=OneWay, StringFormat={}{0:0.###} mm rapid}"/>
                                </TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Estimated Time" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewEstimatedTime, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Preview Note" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap">
                                    <Run Text="Cut moves follow solid paths, rapid moves follow thin red travel lines, and playback stays preview-only without sending machine commands."/>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Machine Visualization" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <controls:CncMachineViewportControl Height="360"
                                                                Motions="{Binding PreviewMotions}"
                                                                CurrentMotionIndex="{Binding CurrentMotionIndex}"
                                                                PreviewCurrentSegmentIndex="{Binding PreviewCurrentSegmentIndex}"
                                                                PreviewSegmentProgress="{Binding PreviewSegmentProgress}"
                                                                UsePreviewPlayback="{Binding UsePreviewPlaybackInViewport}"
                                                                CurrentX="{Binding MachineX}"
                                                                CurrentY="{Binding MachineY}"
                                                                CurrentZ="{Binding MachineZ}"
                                                                WorkOffsetX="{Binding WorkOffsetX}"
                                                                WorkOffsetY="{Binding WorkOffsetY}"
                                                                WorkOffsetZ="{Binding WorkOffsetZ}"
                                                                MachineState="{Binding MachineStateValue}"
                                                                ExecutionState="{Binding ExecutionStateValue}"
                                                                MachineMinX="{Binding XMinMm}"
                                                                MachineMaxX="{Binding XLimitMm}"
                                                                MachineMinY="{Binding YMinMm}"
                                                                MachineMaxY="{Binding YLimitMm}"
                                                                MachineMinZ="{Binding ZMinMm}"
                                                                MachineMaxZ="{Binding ZLimitMm}"
                                                                HasFrameBounds="{Binding HasFrameBounds}"
                                                                FrameMinX="{Binding FrameMinX}"
                                                                FrameMaxX="{Binding FrameMaxX}"
                                                                FrameMinY="{Binding FrameMinY}"
                                                                FrameMaxY="{Binding FrameMaxY}"
                                                                IsFramePreviewActive="{Binding IsFramePreviewActive}"
                                                                PreviewToolX="{Binding PreviewToolX}"
                                                                PreviewToolY="{Binding PreviewToolY}"/>
                            <TextBlock Text="Executed path stays green, the active move is highlighted amber, and the remaining toolpath stays blue while the gantry and tool follow the current estimated machine position."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Execution Progress" FontSize="16" FontWeight="SemiBold"

                                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,5">
                                            <TextBlock Text="{Binding PlacementStatus, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                    </WrapPanel>
                                </Grid>

                                <TabControl Grid.Row="1" Style="{StaticResource CncWorkspaceTabControlStyle}" ItemContainerStyle="{StaticResource CncWorkspaceTabItemStyle}">
                                    <TabItem Header="Toolpath Preview">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <controls:CncToolpathPreviewControl Grid.Row="0"
                                                                                Motions="{Binding PreviewMotions}"
                                                                                CurrentSegmentIndex="{Binding PreviewCurrentSegmentIndex}"
                                                                                SegmentProgress="{Binding PreviewSegmentProgress}"
                                                                                ToolX="{Binding PreviewToolX}"
                                                                                ToolY="{Binding PreviewToolY}"
                                                                                MachineMinX="{Binding XMinMm}"
                                                                                MachineMaxX="{Binding XLimitMm}"
                                                                                MachineMinY="{Binding YMinMm}"
                                                                                MachineMaxY="{Binding YLimitMm}"/>
                                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                                                    <Run Text="Preview: "/>
                                                    <Run Text="{Binding PreviewSimulationStateDisplay, Mode=OneWay}"/>
                                                    <Run Text=" | Segment "/>
                                                    <Run Text="{Binding PreviewCurrentLineText, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center">
                                                    <Run Text="Distance: "/>
                                                    <Run Text="{Binding PreviewTotalDistanceMm, Mode=OneWay, StringFormat={}{0:0.###} mm}"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Right">
                                                    <Run Text="Cut "/>
                                                    <Run Text="{Binding PreviewCutDistanceMm, Mode=OneWay, StringFormat={}{0:0.###}}"/>
                                                    <Run Text=" | Rapid "/>
                                                    <Run Text="{Binding PreviewRapidDistanceMm, Mode=OneWay, StringFormat={}{0:0.###}}"/>
                                                </TextBlock>
                                            </Grid>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Header="Machine View">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <controls:CncMachineViewportControl Grid.Row="0"
                                                                                Motions="{Binding PreviewMotions}"
                                                                                CurrentMotionIndex="{Binding CurrentMotionIndex}"
                                                                                PreviewCurrentSegmentIndex="{Binding PreviewCurrentSegmentIndex}"
                                                                                PreviewSegmentProgress="{Binding PreviewSegmentProgress}"
                                                                                UsePreviewPlayback="{Binding UsePreviewPlaybackInViewport}"
                                                                                CurrentX="{Binding MachineX, Mode=OneWay}"
                                                                                CurrentY="{Binding MachineY, Mode=OneWay}"
                                                                                CurrentZ="{Binding MachineZ, Mode=OneWay}"
                                                                                WorkOffsetX="{Binding WorkOffsetX, Mode=OneWay}"
                                                                                WorkOffsetY="{Binding WorkOffsetY, Mode=OneWay}"
                                                                                WorkOffsetZ="{Binding WorkOffsetZ, Mode=OneWay}"
                                                                                MachineState="{Binding MachineStateValue}"
                                                                                ExecutionState="{Binding ExecutionStateValue}"
                                                                                MachineMinX="{Binding XMinMm}"
                                                                                MachineMaxX="{Binding XLimitMm}"
                                                                                MachineMinY="{Binding YMinMm}"
                                                                                MachineMaxY="{Binding YLimitMm}"
                                                                                MachineMinZ="{Binding ZMinMm}"
                                                                                MachineMaxZ="{Binding ZLimitMm}"
                                                                                HasFrameBounds="{Binding HasFrameBounds}"
                                                                                FrameMinX="{Binding FrameMinX}"
                                                                                FrameMaxX="{Binding FrameMaxX}"
                                                                                FrameMinY="{Binding FrameMinY}"
                                                                                FrameMaxY="{Binding FrameMaxY}"
                                                                                IsFramePreviewActive="{Binding IsFramePreviewActive}"
                                                                                PreviewToolX="{Binding PreviewToolX}"
                                                                                PreviewToolY="{Binding PreviewToolY}"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="Executed path stays green, the active move is highlighted amber, and remaining toolpath stays blue while the machine view follows the current estimated position."
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,12,0,0"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Header="Console">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <DataGrid Grid.Row="0"
                                                      ItemsSource="{Binding SerialLogs}"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      Background="Transparent"
                                                      RowBackground="Transparent"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      BorderThickness="0"
                                                      GridLinesVisibility="Horizontal"
                                                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      CanUserResizeRows="False"
                                                      Margin="0,0,0,10">
                                                <DataGrid.ColumnHeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="Padding" Value="8,6"/>
                                                    </Style>
                                                </DataGrid.ColumnHeaderStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
                                                    <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="80"/>
                                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <ListBox Grid.Row="1" ItemsSource="{Binding OperatorEvents}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="88"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Severity}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Message}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>

                            <Border Grid.Column="4" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Dock" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <TabControl Grid.Row="1" Style="{StaticResource CncWorkspaceTabControlStyle}" ItemContainerStyle="{StaticResource CncWorkspaceTabItemStyle}">
                                        <TabItem Header="Job">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <TextBlock Text="Loaded File" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding LoadedFileName, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                                    <TextBlock Text="Summary" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding LoadedFileSummary, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <TextBlock Text="Interpreter" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding InterpretationSummary, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <TextBlock Text="Placement" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="68"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="68"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Offset X" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding PlacementOffsetX, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Offset Y" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="4" Text="{Binding PlacementOffsetY, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Grid>
                                                    <WrapPanel Margin="0,0,0,10">
                                                        <Button Content="Apply" Command="{Binding ApplyPlacementCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Reset" Command="{Binding ResetPlacementCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Top Left" Command="{Binding PlaceTopLeftCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Top Right" Command="{Binding PlaceTopRightCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Bottom Left" Command="{Binding PlaceBottomLeftCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Bottom Right" Command="{Binding PlaceBottomRightCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Center" Command="{Binding PlaceCenterCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                    </WrapPanel>
                                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                                                        <Run Text="Applied: "/>
                                                        <Run Text="{Binding AppliedPlacementOffsetX, Mode=OneWay, StringFormat={}{0:0.###} X}"/>
                                                        <Run Text=" / "/>
                                                        <Run Text="{Binding AppliedPlacementOffsetY, Mode=OneWay, StringFormat={}{0:0.###} Y}"/>
                                                        <Run Text=" / "/>
                                                        <Run Text="{Binding AppliedPlacementOffsetZ, Mode=OneWay, StringFormat={}{0:0.###} Z}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding PlacementStatus, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding JobBlockingReason}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0" TextWrapping="Wrap" Visibility="{Binding HasBlockingReason, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                    <Separator Margin="0,14,0,14"/>
                                                    <TextBlock Text="Image Toolpath" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Width mm" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding ImageTargetWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Height mm" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="4" Text="{Binding ImageTargetHeightMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Threshold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding ImageThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Simplify" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="4" Text="{Binding ImageSimplifyToleranceMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Min segment" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding ImageMinimumSegmentLengthMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Min area" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="4" Text="{Binding ImageMinimumContourAreaMm2, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Close gap" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding ImageCloseGapToleranceMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Mode" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="4"
                                                                  ItemsSource="{Binding ImageManufacturingModes}"
                                                                  SelectedItem="{Binding ImageManufacturingMode, UpdateSourceTrigger=PropertyChanged}"
                                                                  Background="{DynamicResource BackgroundLightBrush}"
                                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                                  BorderBrush="{DynamicResource BorderBrush}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Cut depth" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding ImageCutDepthMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Safe Z" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="4" Text="{Binding ImageSafeTravelZMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Cut feed" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding ImageCutFeedMmPerMinute, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Plunge" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="4" Text="{Binding ImagePlungeFeedMmPerMinute, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Rapid" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1" Text="{Binding ImageRapidFeedMmPerMinute, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Grid.Column="3" Text="Trace mode" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="4"
                                                                  ItemsSource="{Binding ImageTraceModes}"
                                                                  SelectedItem="{Binding ImageTraceMode, UpdateSourceTrigger=PropertyChanged}"
                                                                  Background="{DynamicResource BackgroundLightBrush}"
                                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                                  BorderBrush="{DynamicResource BorderBrush}"/>
                                                    </Grid>
                                                    <WrapPanel Margin="0,0,0,10">
                                                        <CheckBox Content="Preserve Aspect Ratio" IsChecked="{Binding ImagePreserveAspectRatio}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,14,8"/>
                                                        <CheckBox Content="Invert" IsChecked="{Binding ImageInvert}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,14,8"/>
                                                        <CheckBox Content="Despeckle" IsChecked="{Binding ImageDespeckle}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,14,8"/>
                                                    </WrapPanel>
                                                    <WrapPanel Margin="0,0,0,10">
                                                        <Button Content="Import Image as Toolpath" Command="{Binding ImportImageToolpathCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Generate Preview" Command="{Binding GenerateImageToolpathPreviewCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"/>
                                                        <Button Content="Create G-code Job" Command="{Binding CreateImageToolpathJobCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8"/>
                                                    </WrapPanel>
                                                    <TextBlock Text="{Binding ImageToolpathSummary}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ImageToolpathBoundsText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,8" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ImageToolpathDiagnosticsText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ImageToolpathWarningsText}" Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                    <Grid Visibility="{Binding HasImageToolpathPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="12"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                                                            <StackPanel>
                                                                <TextBlock Text="Original Image" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                                <Border Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Height="180">
                                                                    <Image Source="{Binding ImageToolpathPreviewSource, Mode=OneWay}" Stretch="Uniform"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="2" Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
                                                            <StackPanel>
                                                                <TextBlock Text="Traced Vector Preview" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                                <Border Background="{DynamicResource BackgroundDarkBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Height="180">
                                                                    <Viewbox Stretch="Uniform">
                                                                        <Canvas Width="{Binding ImageTargetWidthMm}" Height="{Binding ImageTargetHeightMm}">
                                                                            <Path Data="{Binding ImageBoundingBoxGeometryData, Mode=OneWay}"
                                                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                                                  StrokeThickness="0.8"
                                                                                  StrokeDashArray="2,2"
                                                                                  Fill="Transparent"/>
                                                                            <Path Data="{Binding ImageRapidGeometryData, Mode=OneWay}"
                                                                                  Stroke="{DynamicResource WarningBrush}"
                                                                                  StrokeThickness="0.9"
                                                                                  StrokeDashArray="3,2"
                                                                                  Fill="Transparent"/>
                                                                            <Path Data="{Binding ImageTraceGeometryData, Mode=OneWay}"
                                                                                  Stroke="{DynamicResource AccentBrush}"
                                                                                  StrokeThickness="1.5"
                                                                                  Fill="Transparent"/>
                                                                            <ItemsControl ItemsSource="{Binding ImagePreviewMarkers, Mode=OneWay}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <Canvas/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemContainerStyle>
                                                                                    <Style TargetType="ContentPresenter">
                                                                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                                                                    </Style>
                                                                                </ItemsControl.ItemContainerStyle>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Grid>
                                                                                            <Ellipse Width="4" Height="4" Fill="{DynamicResource AccentBrush}"/>
                                                                                            <TextBlock Text="{Binding Label}"
                                                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                                       FontSize="3.5"
                                                                                                       Margin="4,-1,0,0"/>
                                                                                        </Grid>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </Canvas>
                                                                    </Viewbox>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </TabItem>

                                        <TabItem Header="Execution">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="State" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ExecutionStateDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Streaming" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StreamingStateDisplay, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Line" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentLineNumber, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Command" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentStreamedCommand, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Raw Line" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentRawLine, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Progress" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ProgressSummary, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Metrics" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding StreamingProgressSummary, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Failed Line" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding FailedLineNumber}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Result" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SessionResultText, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </ScrollViewer>
                                        </TabItem>

                                        <TabItem Header="Safety">
                                            <StackPanel>
                                                <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ReferenceStatusText, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding ReferenceWarningText, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" Visibility="{Binding HasReferenceWarning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding ZReferenceStatusText, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                                                        <TextBlock Text="{Binding ZReferenceWarningText, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" Visibility="{Binding HasZReferenceWarning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="Current Alarm" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding CurrentAlarmText, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                                <TextBlock Text="Current Warning" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding CurrentWarningText, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                                <TextBlock Text="Diagnostics" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding DiagnosticsSummary, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                                <TextBlock Text="Last Error" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding LastError, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </TabItem>

                                        <TabItem Header="Recovery">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding RecoveryStateText, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding RecoverySeverityText, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,10"/>

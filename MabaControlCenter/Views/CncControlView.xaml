                                            <Button Content="Refresh" Command="{Binding RefreshPortsCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Connect" Command="{Binding ConnectCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                        </WrapPanel>

                                        <TextBlock Text="Machine Actions" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <WrapPanel Margin="0,0,0,14">
                                            <Button Content="{Binding EnableOrUnlockButtonText}"
                                                    Command="{Binding EnableMotorsCommand}"
                                                    Style="{StaticResource CncPrimaryButtonStyle}"
                                                    Margin="0,0,8,8"
                                                    Visibility="{Binding ShowEnableOrUnlockControl, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Content="Disable Motors"
                                                    Command="{Binding DisableMotorsCommand}"

                                            <Button Content="Load G-code" Command="{Binding LoadGcodeCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Import Image" Command="{Binding ImportImageToolpathCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Clear Job" Command="{Binding ClearLoadedProgramCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Frame" Command="{Binding FramePreviewCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Start" Command="{Binding StartProgramCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Pause" Command="{Binding PauseProgramCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Resume" Command="{Binding ResumeProgramCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Software Stop" Command="{Binding StopCommand}" Style="{StaticResource CncDangerButtonStyle}" Margin="0,0,8,8"/>
                                        </WrapPanel>

                                        <TextBlock Text="Connection" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>

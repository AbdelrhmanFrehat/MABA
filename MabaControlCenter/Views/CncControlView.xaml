                                            <TextBlock Text="{Binding RuntimeBlockingReasonText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Workspace" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LoadedFileSummary, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Bottom">
                                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding JobSessionStateDisplay, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>

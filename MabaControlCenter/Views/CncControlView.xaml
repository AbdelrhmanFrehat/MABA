                                    Command="{Binding SetZeroYCommand}"
                                    Style="{StaticResource CncPrimaryButtonStyle}"
                                    MinWidth="94"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"/>
                            <Button Content="Set Zero XY"
                                    Command="{Binding SetZeroXyCommand}"
                                    Style="{StaticResource CncPrimaryButtonStyle}"
                                    MinWidth="98"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"/>
                            <Button Content="Set Z Zero"
                                    Command="{Binding SetZeroZCommand}"
                                    Style="{StaticResource CncPrimaryButtonStyle}"
                                    MinWidth="98"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"/>
                            <Button Content="Clear Z Zero"
                                    Command="{Binding ClearZZeroCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="104"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"/>
                            <Button Content="Clear Work Zero"
                                    Command="{Binding ClearWorkZeroCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="120"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"/>
                            <Button Content="Reset Alarm"
                                    Command="{Binding ResetStateCommand}"
                                    Style="{StaticResource CncDangerButtonStyle}"
                                    MinWidth="112"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding CanResetState, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Content="Clear Warning"
                                    Command="{Binding ClearWarningCommand}"
                                    Style="{StaticResource CncPrimaryButtonStyle}"
                                    MinWidth="112"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"/>
                            <Button Content="Status"
                                    Command="{Binding RefreshStatusCommand}"
                                    Style="{StaticResource CncPrimaryButtonStyle}"
                                    MinWidth="86"
                                    MinHeight="34"
                                    Padding="10,6"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding ShowStatusControl, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding LastFeedback, Mode=OneWay}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.RowSpan="2"
              Background="#99000000"
              Visibility="{Binding IsMachineWizardOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="980"
                    MaxHeight="720"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource BackgroundLightBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#AA000000" BlurRadius="28" ShadowDepth="6" Opacity="0.45"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Add / Switch Machine"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="A focused machine onboarding flow. Pick one thing per step, then confirm the runtime profile switch."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding WizardSteps}" Margin="0,16,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource WizardStepPillStyle}" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid Grid.Row="1" ClipToBounds="True">
                        <Border Style="{StaticResource WizardStepPaneStyle}"
                                Visibility="{Binding IsWizardCatalogStep, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="560">
                                <TextBlock Text="Catalog"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding WizardSyncDisplay}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border CornerRadius="12"
                                        Padding="10,5"
                                        Background="{DynamicResource BackgroundMediumBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,18">
                                    <TextBlock Text="{Binding WizardConnectivityText}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>
                                <Button Content="Sync Machine Catalog"
                                        Command="{Binding SyncMachineCatalogCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,18"/>
                                <TextBlock Text="No machines available. Sync to continue."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding HasWizardMachines, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding MachineCatalogSyncStatus}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WizardStepPaneStyle}"
                                Visibility="{Binding IsWizardFamilyStep, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Choose Machine Family"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,14"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding WizardFamilyCards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectWizardFamilyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource WizardCardButtonStyle}"
                                                        Width="286"
                                                        Height="132">
                                                    <Grid Margin="16">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="42"
                                                                Height="42"
                                                                CornerRadius="21"
                                                                Background="{DynamicResource BackgroundLightBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding IconText}"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       FontSize="18"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="15"/>
                                                            <TextBlock Text="{Binding Subtitle}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       MaxHeight="48"
                                                                       Margin="0,5,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WizardStepPaneStyle}"
                                Visibility="{Binding IsWizardMachineStep, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Choose Machine"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,14"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding WizardMachineCards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectWizardMachineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource WizardCardButtonStyle}"
                                                        Height="170"
                                                        HorizontalAlignment="Stretch">
                                                    <Grid Margin="16">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="210"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BackgroundDarkBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Margin="0,0,16,0">
                                                            <Grid>
                                                                <Image Source="{Binding ImageUrl}"
                                                                       Stretch="Uniform"
                                                                       Margin="10"
                                                                       Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <TextBlock Text="â–±"
                                                                           FontSize="54"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding ImagePlaceholderText}"
                                                                           FontSize="12"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Bottom"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"
                                                                           Margin="14"
                                                                           Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="17"/>
                                                            <TextBlock Text="{Binding VersionText}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Margin="0,2,0,6"/>
                                                            <TextBlock Text="{Binding Subtitle}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       MaxHeight="42"/>
                                                            <WrapPanel Margin="0,12,0,8">
                                                                <TextBlock Text="{Binding WorkspaceText, StringFormat=Workspace: {0}}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           Margin="0,0,18,0"/>
                                                                <TextBlock Text="{Binding AxesText, StringFormat=Axes: {0}}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            </WrapPanel>
                                                            <ItemsControl ItemsSource="{Binding Tags}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{DynamicResource BackgroundLightBrush}"
                                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="10"
                                                                                Padding="8,3"
                                                                                Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WizardStepPaneStyle}"
                                Visibility="{Binding IsWizardModeStep, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Choose Setup Mode"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,18"/>
                                <ItemsControl ItemsSource="{Binding WizardModeCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectWizardModeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource WizardCardButtonStyle}"
                                                    Width="250"
                                                    Height="150">
                                                <StackPanel Margin="18" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding IconText}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontSize="28"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,0,0,8"/>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontWeight="SemiBold"
                                                               FontSize="16"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               Margin="0,8,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource WizardStepPaneStyle}"
                                Visibility="{Binding IsWizardConfirmStep, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="620">
                                <TextBlock Text="Confirm Machine"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,18"/>
                                <Border Background="{DynamicResource BackgroundMediumBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Machine" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8">
                                            <Run Text="{Binding WizardSelectedMachineFamily.DisplayNameEn}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding WizardSelectedMachineDefinition.DisplayNameEn}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mode" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WizardSelectedSetupMode}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Driver" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WizardSelectedMachineDefinition.DefaultDriverType}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Profile" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Default system profile will be auto-created or reused." Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding MachinePlatformStatus}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="Back"
                                Command="{Binding WizardBackCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="12,0,8,0"/>
                        <Button Grid.Column="2"
                                Content="Cancel"
                                Command="{Binding CloseMachineWizardCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="3"
                                Content="{Binding WizardNextButtonText}"
                                Command="{Binding WizardNextCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2"
              Background="#99000000"
              Visibility="{Binding IsMachineSwitchOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="860"
                    MaxHeight="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource BackgroundLightBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#AA000000" BlurRadius="28" ShadowDepth="6" Opacity="0.45"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,18">
                        <TextBlock Text="Switch Existing Machine"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Choose from machines you already added. Use Add Machine only for a brand-new machine."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <StackPanel Visibility="{Binding HasExistingMachines, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Previously Added Machines"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,14"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ExistingMachineCards}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectExistingMachineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource WizardCardButtonStyle}"
                                                    Height="126"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,12">
                                                <Grid Margin="16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="16"/>
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Margin="0,4,0,8"
                                                                   TextWrapping="Wrap"/>
                                                        <WrapPanel>
                                                            <Border CornerRadius="8"
                                                                    Padding="10,5"
                                                                    Background="{DynamicResource BackgroundLightBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    Margin="0,0,8,6">
                                                                <TextBlock Text="{Binding ProfileText}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           FontSize="11"/>
                                                            </Border>
                                                            <Border CornerRadius="8"
                                                                    Padding="10,5"
                                                                    Background="{DynamicResource BackgroundLightBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    Margin="0,0,8,6">
                                                                <TextBlock Text="{Binding ModeText}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           FontSize="11"/>
                                                            </Border>
                                                            <Border CornerRadius="8"
                                                                    Padding="10,5"
                                                                    Background="{DynamicResource BackgroundLightBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    Margin="0,0,8,6">
                                                                <TextBlock Text="{Binding DriverText}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           FontSize="11"/>
                                                            </Border>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding StatusText}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Top"
                                                               Margin="18,0,0,0"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasExistingMachines, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="No added machines found yet."
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Use Add Machine to onboard your first machine normally."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="420"
                                       Margin="0,0,0,18"/>
                            <Button Content="Add Machine"
                                    Command="{Binding OpenMachineWizardCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding MachinePlatformStatus}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="Cancel"
                                Command="{Binding CloseMachineSwitchCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="12,0,8,0"/>
                        <Button Grid.Column="2"
                                Content="Use This Machine"
                                Command="{Binding ConfirmExistingMachineSwitchCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>




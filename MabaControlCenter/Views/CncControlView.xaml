                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="State" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ExecutionStateDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Line" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentLineNumber}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Raw Line" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentRawLine}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Progress" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ProgressSummary}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Session Started" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SessionStartedAtDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Last Action" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SessionLastAction}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Session Result" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SessionResultText}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            </Grid>
                            <TextBlock Text="{Binding SessionSummaryText}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Safety Status" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Current Alarm" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentAlarmText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Warning" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentWarningText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Diagnostics" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DiagnosticsSummary}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Error" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastError}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{Binding Source={StaticResource Labels}, Path=Cnc_Tab_Monitor}">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Serial Log" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding SerialLogs}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                                      MaxHeight="320">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
                                    <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="120"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Operator Session Log" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding OperatorEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundMediumBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Severity}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Message}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Warnings / Errors / Interruptions" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding DiagnosticsMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundMediumBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No active diagnostics."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding HasDiagnostics, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Machine State" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="State" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MachineStateDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Connection" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ConnectionStatusText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Motors" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MotorsEnabled}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Execution Ready" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CanStartProgram}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Protocol Sync" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Device Ready" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeviceReadyDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Device State" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DeviceStateDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Position Source" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PositionTrackingDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Reported Position" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DeviceReportedPositionText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Last Ack" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastAcknowledgementText}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Protocol Status" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ProtocolStatusText}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            </Grid>
                            <TextBlock Text="{Binding ProtocolErrorText}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Position" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="Machine Position (mm)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <UniformGrid Columns="3" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="X" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding MachineX, StringFormat={}{0:0.###}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Y" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding MachineY, StringFormat={}{0:0.###}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Z" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding MachineZ, StringFormat={}{0:0.###}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="Work Position (mm)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <UniformGrid Columns="3">
                                <StackPanel>
                                    <TextBlock Text="X" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding WorkX, StringFormat={}{0:0.###}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Y" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding WorkY, StringFormat={}{0:0.###}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Z" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding WorkZ, StringFormat={}{0:0.###}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Source={StaticResource Labels}, Path=Cnc_Tab_Setup}">
                    <StackPanel Margin="0,16,0,0">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Machine Profiles &amp; Calibration" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="Choose the machine definition and runtime profile used by the CNC workspace. Advanced calibration is available below when you need it."
                                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="Active Machine" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,8"/>
                                <Border Background="{DynamicResource BackgroundMediumBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ActiveProfileName, StringFormat=Machine/Profile: {0}}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding ActiveMachineContextText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,4"/>
                                            <WrapPanel>
                                                <TextBlock Text="{Binding ActiveProfileDriver, StringFormat=Driver: {0}}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Margin="0,0,18,4"/>
                                                <TextBlock Text="{Binding EffectiveCapabilitiesSummary, StringFormat=Capabilities: {0}}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </WrapPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MachineCatalogSyncStatus}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="260"
                                                   Margin="18,0,0,0"/>
                                    </Grid>
                                </Border>

                                <WrapPanel Margin="0,0,0,8">
                                    <Button Content="Add Machine"
                                            Command="{Binding OpenMachineWizardCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="0,0,8,8"/>
                                    <Button Content="Switch Machine"
                                            Command="{Binding OpenMachineWizardCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,8"/>
                                    <Button Content="Sync Catalog"
                                            Command="{Binding SyncMachineCatalogCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,8"/>
                                    <Button Content="Manage Profiles"
                                            Command="{Binding ManageProfilesCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,8"/>
                                </WrapPanel>
                                <TextBlock Text="{Binding MachinePlatformStatus}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Expander Header="Advanced: custom profiles and calibration"
                                      IsExpanded="{Binding IsProfileManagerOpen, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource BackgroundLightBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      Margin="0,0,0,0">
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="Create Custom Profile" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="260"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Custom Name" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding NewRuntimeProfileName, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Grid.Column="2"
                                                Content="New Custom Profile"
                                                Command="{Binding CreateRuntimeProfileCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,8,0"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="Use this only when a system default needs an editable copy."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <TextBlock Text="Runtime Profile Management" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Selected Runtime" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding RuntimeProfiles}"
                                                  SelectedItem="{Binding SelectedRuntimeProfile, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemTemplate="{StaticResource RuntimeProfileDisplayTemplate}"
                                                  Background="{DynamicResource BackgroundLightBrush}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                  Margin="0,0,12,0"/>
                                        <Button Grid.Column="2" Content="Activate"
                                                Command="{Binding ActivateRuntimeProfileCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="3" Content="Duplicate"
                                                Command="{Binding DuplicateRuntimeProfileCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="4" Content="Delete"
                                                Command="{Binding DeleteRuntimeProfileCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Calibration Profile" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding Profiles}"
                                                  SelectedItem="{Binding SelectedProfile, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="ProfileName"
                                                  Background="{DynamicResource BackgroundLightBrush}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                  Margin="0,0,12,0"/>
                                        <Button Grid.Column="2" Content="Apply Active"
                                                Command="{Binding ApplyProfileCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="3" Content="Duplicate"
                                                Command="{Binding DuplicateProfileCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="4" Content="Delete"
                                                Command="{Binding DeleteProfileCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </Grid>

                                    <WrapPanel Margin="0,0,0,12">
                                        <TextBlock Text="{Binding ActiveProfileName, StringFormat=Active: {0}}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,18,4"/>
                                        <TextBlock Text="{Binding ActiveProfileDriver, StringFormat=Driver: {0}}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,18,4"/>
                                        <TextBlock Text="{Binding SelectedProfileKindDisplay}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="0,0,18,4"/>
                                        <TextBlock Text="{Binding ProfilePermissionHint}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </WrapPanel>

                                    <StackPanel IsEnabled="{Binding CanEditSelectedProfile}">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile Name" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,8"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Notes" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top" Margin="0,0,12,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProfileNotes, UpdateSourceTrigger=PropertyChanged}" Height="56" AcceptsReturn="True" TextWrapping="Wrap"/>

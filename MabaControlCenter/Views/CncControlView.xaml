                                            <Button Content="Set Zero XY" Command="{Binding SetZeroXyCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Set Z Zero" Command="{Binding SetZeroZCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Clear Z Zero" Command="{Binding ClearZZeroCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Clear Work Zero" Command="{Binding ClearWorkZeroCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                        </WrapPanel>

                                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">

                                                    <Button Grid.Row="0" Grid.Column="1" Content="Y+" Command="{Binding JogYPositiveCommand}" Style="{StaticResource CncJogButtonStyle}" Width="74" Height="44" FontSize="14" Margin="4"/>
                                                    <Button Grid.Row="1" Grid.Column="0" Content="X-" Command="{Binding JogXNegativeCommand}" Style="{StaticResource CncJogButtonStyle}" Width="74" Height="44" FontSize="14" Margin="4"/>

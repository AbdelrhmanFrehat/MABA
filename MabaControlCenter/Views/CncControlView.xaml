                                            <Button Content="Home XY" Command="{Binding HomeCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Go To Center" Command="{Binding GoToCenterCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Refresh Status" Command="{Binding RefreshStatusCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                            <Button Content="Reset Alarm"
                                                    Command="{Binding ResetStateCommand}"
                                                    Style="{StaticResource CncDangerButtonStyle}"
                                                    Margin="0,0,8,8"
                                                    Visibility="{Binding CanResetState, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Content="Clear Warning" Command="{Binding ClearWarningCommand}" Style="{StaticResource CncPrimaryButtonStyle}" Margin="0,0,8,8"/>
                                        </WrapPanel>

                                        <TextBlock Text="Manual Jog" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <StackPanel Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                                <TextBlock Text="Jog Step" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ComboBox Width="94" ItemsSource="{Binding JogStepPresets}" SelectedItem="{Binding SelectedJogStep, UpdateSourceTrigger=PropertyChanged}"/>

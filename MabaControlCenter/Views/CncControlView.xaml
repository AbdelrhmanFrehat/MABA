                                                <TextBlock Text="{Binding ZReferenceWarningText, Mode=OneWay}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" Visibility="{Binding HasZReferenceWarning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                                                    <Run Text="Current Z: "/>
                                                    <Run Text="{Binding WorkZ, Mode=OneWay, StringFormat={}{0:0.###} mm}"/>

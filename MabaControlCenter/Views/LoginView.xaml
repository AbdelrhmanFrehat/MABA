<UserControl x:Class="MabaControlCenter.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.75,0.15" RadiusX="0.85" RadiusY="0.85">
                <GradientStop Color="#223B82F6" Offset="0"/>
                <GradientStop Color="#00000000" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Border Width="460"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource CardBorderStyle}"
                Padding="34">
            <StackPanel>
                <TextBlock Text="MABA Control Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Sign in with your MABA website account."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Use your MABA website account"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           Opacity="0.82"
                           Margin="0,0,0,26"/>

                <TextBlock Text="Email" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="42"
                         Margin="0,0,0,14"
                         VerticalContentAlignment="Center"/>

                <TextBlock Text="Password" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordInput"
                             MinHeight="42"
                             Margin="0,0,0,10"
                             PasswordChanged="PasswordInput_OnPasswordChanged"/>

                <Grid Margin="0,0,0,18">
                    <CheckBox Content="Remember Me"
                              IsChecked="{Binding RememberMe, UpdateSourceTrigger=PropertyChanged}"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <Button Content="Forgot Password?"
                            Command="{Binding ForgotPasswordCommand}"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource AccentBrush}"
                            Cursor="Hand"
                            Padding="0"/>
                </Grid>

                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinHeight="44"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ProgressBar Width="18"
                                     Height="18"
                                     IsIndeterminate="True"
                                     Margin="0,0,8,0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding SignInButtonText}"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Don't have an account? "
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="Create one"
                            Command="{Binding CreateAccountCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource AccentBrush}"
                            Cursor="Hand"
                            Padding="0"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="MabaControlCenter.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" VerticalAlignment="Top">
            <Border CornerRadius="18"
                    Padding="18,20,24,20"
                    Margin="0,0,0,22"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource HomeHeroBackgroundBrush}">
                <Grid MinHeight="150">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="0.75*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="/Assets/maba-logo-transparent.png"
                               Grid.Column="0"
                               Width="170"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Top"
                               Margin="0,0,0,0"/>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="MABA Control Center"
                                       Foreground="{DynamicResource HomeHeroTitleBrush}"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Control. Simulate. Execute."
                                       Foreground="{DynamicResource HomeHeroSubtitleBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Unified platform for CNC, robotics, and automation systems."
                                       Foreground="{DynamicResource HomeHeroDescriptionBrush}"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <Canvas Grid.Column="2" ClipToBounds="True" Opacity="0.9">
                        <Path Stroke="{DynamicResource HomeHeroVisualGridBrush}" StrokeThickness="1" Data="M 24 50 L 260 50 L 306 112 L 70 112 Z"/>
                        <Path Stroke="{DynamicResource HomeHeroVisualGridBrush}" StrokeThickness="1" Opacity="0.65" Data="M 42 72 L 278 72 M 58 94 L 294 94 M 82 53 L 50 110 M 132 53 L 100 110 M 182 53 L 150 110 M 232 53 L 200 110"/>
                        <Path Stroke="{DynamicResource HomeHeroVisualStrokeBrush}" StrokeThickness="3" Data="M 70 104 L 142 78 L 214 100 L 282 60"/>
                        <Ellipse Canvas.Left="206" Canvas.Top="92" Width="14" Height="14" Fill="{DynamicResource HomeHeroVisualStrokeBrush}"/>
                    </Canvas>
                </Grid>
            </Border>

            <TextBlock Text="Quick Access" FontSize="17" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding QuickAccessCards}" Margin="0,0,0,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding Command}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinHeight="42"
                                MinWidth="150"
                                Margin="0,0,10,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Active Machine" FontSize="17" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
            <Border BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="0,14"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold">
                            <Run Text="Machine: "/>
                            <Run Text="{Binding ActiveMachineName, Mode=OneWay}"/>
                        </TextBlock>
                        <WrapPanel Margin="0,8,0,0">
                            <TextBlock Text="{Binding ActiveMachineStatus, StringFormat=Status: {0}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,26,0"/>
                            <TextBlock Text="{Binding ActiveMachineMode, StringFormat=Mode: {0}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </WrapPanel>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Content="Open Control Panel"
                                Command="{Binding OpenControlPanelCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="Switch Machine"
                                Command="{Binding AddMachineCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Expander IsExpanded="False" Margin="0,0,0,24">
                <Expander.Header>
                    <TextBlock Text="What's New" FontSize="17" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Expander.Header>
                <ItemsControl ItemsSource="{Binding WhatIsNew}" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Description}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <TextBlock Text="Modules" FontSize="17" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding ModuleRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Description}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Margin="0,0,18,0"/>
                                <Button Grid.Column="2"
                                        Command="{Binding Command}"
                                        IsEnabled="{Binding IsAvailable}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        HorizontalAlignment="Right"
                                        MinWidth="112"
                                        Content="{Binding ActionText}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

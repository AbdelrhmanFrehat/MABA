<UserControl x:Class="MabaControlCenter.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" VerticalAlignment="Top">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding PlaceholderText}" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <!-- Top status row: System, Devices, Modules -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- System Status -->
                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="System Status" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding UpdateInfo.StatusMessage}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    </StackPanel>
                </Border>

                <!-- Connected Devices -->
                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Connected Devices" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ConnectedDeviceName}" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ConnectedDeviceHint}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Active Modules -->
                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="16,0,0,0">
                    <StackPanel>
                        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Active Modules" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ActiveModulesStatus}" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding RecommendedModuleHint}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_AppVersionUpdates}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_CurrentVersion}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding UpdateInfo.CurrentVersion}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_LatestVersion}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding UpdateInfo.LatestVersion}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                    <TextBlock Text="{Binding UpdateInfo.StatusMessage}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <Button Content="{Binding Source={StaticResource Labels}, Path=Button_CheckForUpdates}" Command="{Binding CheckForUpdatesCommand}"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_WhatsNew}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding NewsItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Description}" FontSize="13" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Date, StringFormat={}{0:MMMM d, yyyy}}"
                                           Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

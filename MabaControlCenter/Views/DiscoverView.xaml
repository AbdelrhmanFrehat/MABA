<UserControl x:Class="MabaControlCenter.Views.DiscoverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" VerticalAlignment="Top">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding PlaceholderText}" FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <!-- Featured Products -->
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_FeaturedProducts}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="14" Margin="0,0,6,0" >
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Product_DexterVP1}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Product_DexterVP1_Desc}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="14" Margin="3,0" >
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Product_Scara}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Product_Scara_Desc}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="14" Margin="6,0,0,0" >
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Product_CNC}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Product_CNC_Desc}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Featured Modules -->
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_FeaturedModules}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Dexter Calibration - Available -->
                <Border Grid.Column="0" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="14" Margin="0,0,6,0" >
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Discover_Module_DexterCal}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{DynamicResource AccentBrush}" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Status_Available}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Module_DexterCal_Desc}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <!-- SCARA Control - Coming Soon -->
                <Border Grid.Column="1" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="14" Margin="3,0" >
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Discover_Module_ScaraControl}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundMediumBrush}" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Status_ComingSoon}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Module_ScaraControl_Desc}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <!-- CNC Manager - Coming Soon -->
                <Border Grid.Column="2" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" Padding="14" Margin="6,0,0,0" >
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Discover_Module_CNCManager}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundMediumBrush}" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Status_ComingSoon}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_Module_CNCManager_Desc}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Discover_QuickActions}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="{Binding Source={StaticResource Labels}, Path=Discover_Action_Website}"
                        Command="{Binding OpenUrlCommand}" CommandParameter="{Binding MabaWebsiteUrlValue}"
                        Padding="14,8" Margin="0,0,10,0" MinWidth="130"
                        Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderThickness="0" Cursor="Hand"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Discover_Action_StartProject}"
                        Command="{Binding OpenUrlCommand}" CommandParameter="{Binding MabaProjectsUrlValue}"
                        Padding="14,8" Margin="0,0,10,0" MinWidth="130"
                        Background="{DynamicResource BackgroundLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                <Button Content="{Binding Source={StaticResource Labels}, Path=Discover_Action_Support}"
                        Command="{Binding OpenUrlCommand}" CommandParameter="{Binding MabaSupportUrlValue}"
                        Padding="14,8" MinWidth="130"
                        Background="{DynamicResource BackgroundLightBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

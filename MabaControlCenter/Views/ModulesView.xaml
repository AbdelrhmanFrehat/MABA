<UserControl x:Class="MabaControlCenter.Views.ModulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
        <StackPanel Margin="24" VerticalAlignment="Top">
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Page_Modules_Title}" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Page_Modules_Placeholder}" FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <ItemsControl ItemsSource="{Binding Modules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Margin="0,0,0,12" Padding="0" BorderThickness="0" Background="Transparent"
                                Cursor="Hand"
                                Command="{Binding DataContext.OpenModuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{DynamicResource BackgroundLightBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Padding="16">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Module.Name}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Module.Code}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{DynamicResource AccentBrush}" CornerRadius="4"
                                            Padding="8,4" VerticalAlignment="Center"
                                            Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_RecommendedForDevice}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding Module.Description}" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_Version}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Module.Version}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_Installed}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource BoolToLocalizedYesNoConverter}">
                                                <Binding Path="Module.IsInstalled"/>
                                                <Binding Source="{StaticResource Labels}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_Enabled}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource BoolToLocalizedYesNoConverter}">
                                                <Binding Path="Module.IsEnabled"/>
                                                <Binding Source="{StaticResource Labels}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>

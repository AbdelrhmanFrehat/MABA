<UserControl x:Class="MabaControlCenter.Views.JobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding Subtitle}" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Status" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox Width="160"
                          ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter, UpdateSourceTrigger=PropertyChanged}"
                          Background="{DynamicResource BackgroundLightBrush}"
                          Foreground="{DynamicResource TextOnLightBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"/>
            </StackPanel>
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Machine Type" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox Width="160"
                          ItemsSource="{Binding MachineFilters}"
                          SelectedItem="{Binding SelectedMachineFilter, UpdateSourceTrigger=PropertyChanged}"
                          Background="{DynamicResource BackgroundLightBrush}"
                          Foreground="{DynamicResource TextOnLightBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"/>
            </StackPanel>
            <StackPanel VerticalAlignment="Bottom">
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Padding="12,8"
                        Background="{DynamicResource BackgroundLightBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Jobs}"
                              SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              RowBackground="Transparent"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource BackgroundMediumBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Reference" Binding="{Binding JobReference}" Width="150"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding SourceType}" Width="120"/>
                            <DataGridTextColumn Header="Machine" Binding="{Binding MachineType}" Width="110"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat={}{0:g}}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1"
                            Background="{DynamicResource BackgroundLightBrush}"
                            Visibility="{Binding HasJobs, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding EmptyStateTitle}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding EmptyStateHint}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedJobDetail.JobReference}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedJobDetail.Title}" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                        <WrapPanel Margin="0,0,0,12">
                            <Button Content="Approve"
                                    Command="{Binding ApproveCommand}"
                                    Visibility="{Binding CanApprove, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Padding="12,8" Margin="0,0,8,8"
                                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="Start"
                                    Command="{Binding StartCommand}"
                                    Visibility="{Binding CanStart, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Padding="12,8" Margin="0,0,8,8"
                                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="Complete"
                                    Command="{Binding CompleteCommand}"
                                    Visibility="{Binding CanComplete, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Padding="12,8" Margin="0,0,8,8"
                                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button Content="Fail"
                                    Command="{Binding FailCommand}"
                                    Visibility="{Binding CanFail, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Padding="12,8" Margin="0,0,8,8"
                                    Background="{DynamicResource BackgroundMediumBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                            <Button Content="Cancel"
                                    Command="{Binding CancelCommand}"
                                    Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Padding="12,8" Margin="0,0,8,8"
                                    Background="{DynamicResource BackgroundMediumBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Cursor="Hand"/>
                        </WrapPanel>

                        <TextBlock Text="Overview" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Source" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SourceLabel}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Source Ref" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedJobDetail.SourceReference}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Machine" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MachineLabel}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Status" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedJobDetail.Status}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Customer" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedJobDetail.CustomerName}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Created" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedJobDetail.CreatedAt, StringFormat={}{0:g}}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Assigned Device" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding AssignedDeviceLabel}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>

                        <TextBlock Text="Description" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                            <TextBlock Text="{Binding SelectedJobDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>

                        <TextBlock Text="Device Readiness" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding ActiveDeviceSummary}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding CompatibilityText}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Files" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding FileUrl}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding FilePath}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Payload" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding PayloadEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Key}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                            <TextBlock Text="{Binding Value}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="MabaControlCenter.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDarkBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" VerticalAlignment="Top">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding PlaceholderText}" FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <!-- Appearance -->
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Settings_Appearance}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Settings_AppearanceHelp}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_Theme}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding SelectedTheme, UpdateSourceTrigger=PropertyChanged}"
                                  Width="180" MinHeight="26" HorizontalAlignment="Left"
                                  Background="{DynamicResource BackgroundLightBrush}"
                                  Foreground="{DynamicResource TextOnLightBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Language -->
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Label_Language}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Settings_LanguageHelp}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguage, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="DisplayName"
                                  Width="180" MinHeight="26" HorizontalAlignment="Left"
                                  Background="{DynamicResource BackgroundLightBrush}"
                                  Foreground="{DynamicResource TextOnLightBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- App Preferences -->
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Settings_AppPreferences}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <CheckBox Content="{Binding Source={StaticResource Labels}, Path=Settings_StartWithWindows}"
                              IsChecked="{Binding StartWithWindows, UpdateSourceTrigger=PropertyChanged}"
                              Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <CheckBox Content="{Binding Source={StaticResource Labels}, Path=Settings_CheckForUpdatesAuto}"
                              IsChecked="{Binding CheckForUpdatesAuto, UpdateSourceTrigger=PropertyChanged}"
                              Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <CheckBox Content="{Binding Source={StaticResource Labels}, Path=Settings_DiagnosticsMode}"
                              IsChecked="{Binding DiagnosticsMode, UpdateSourceTrigger=PropertyChanged}"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- About: MABA Solutions (structured content from website, adapted for app) -->
            <TextBlock Text="{Binding Source={StaticResource Labels}, Path=Settings_About}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="MABA Solutions" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Engineering High-Performance Systems" FontSize="13"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Custom robotics, CNC platforms, embedded systems, and intelligent industrial solutions."
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Direction -->
                    <TextBlock Text="Direction" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="• Medical machines and assistive technologies" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• Smart diagnostic and monitoring systems" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• Embedded real-time control systems" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• Hardware + firmware + software integration" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• Engineering systems that solve real problems" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,0"/>
                    </StackPanel>

                    <!-- Medical Systems Focus -->
                    <TextBlock Text="Medical Systems Focus" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="• Patient monitoring systems" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• Assistive and rehabilitation devices" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• Embedded healthcare control systems" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• Medical data &amp; analytics platforms" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="• IoT monitoring solutions" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,0"/>
                    </StackPanel>

                    <!-- Engineering Discipline (highlight) -->
                    <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Every project follows:" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="• Engineering discipline and traceability" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="• Documentation discipline" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="• Testing and validation" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="• Ethical responsibility" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Technology Capabilities (cards) -->
                    <TextBlock Text="Technology Capabilities" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <WrapPanel Margin="0,0,0,12">
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="10" Margin="0,0,8,8">
                            <TextBlock Text="Embedded systems &amp; firmware" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="10" Margin="0,0,8,8">
                            <TextBlock Text="Robotics and automation" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="10" Margin="0,0,8,8">
                            <TextBlock Text="Monitoring and data systems" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="10" Margin="0,0,8,8">
                            <TextBlock Text="Industrial control interfaces" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="10" Margin="0,0,8,8">
                            <TextBlock Text="Engineering prototypes &amp; R&amp;D" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <Border Background="{DynamicResource BackgroundMediumBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Padding="10" Margin="0,0,8,8">
                            <TextBlock Text="Software platforms (analysis &amp; GUI)" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                    </WrapPanel>

                    <!-- Integration statement -->
                    <TextBlock Text="Hardware • Firmware • Software • Mechanical design • System validation"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="All under one structured engineering workflow."
                               FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Product Philosophy: two columns -->
                    <TextBlock Text="Product Philosophy" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="• Software systems and platforms" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="• Hardware devices" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="• Engineering integrations" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="• R&amp;D prototypes" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="• Commercial tools" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="1. Functional reliability" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="2. Clean system architecture" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="3. Clear documentation" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="4. Professional presentation" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="5. Brand consistency" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- App / Version / Company -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Settings_Label_AppName}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Source={StaticResource Labels}, Path=Settings_AppName}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Label_Version}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Source={StaticResource Labels}, Path=Settings_Version}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Source={StaticResource Labels}, Path=Settings_Label_Company}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Source={StaticResource Labels}, Path=Settings_Company}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

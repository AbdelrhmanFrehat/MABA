<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme color palette -->
    <Color x:Key="BackgroundDark">#FF1A1D21</Color>
    <Color x:Key="BackgroundMedium">#FF25282E</Color>
    <Color x:Key="BackgroundLight">#FF2D3139</Color>
    <Color x:Key="SidebarColor">#FF1E2128</Color>
    <Color x:Key="HeaderColor">#FF25282E</Color>
    <Color x:Key="AccentColor">#FF4A9E5C</Color>
    <Color x:Key="AccentHover">#FF5BB86D</Color>
    <Color x:Key="TextPrimary">#FFE8EAED</Color>
    <Color x:Key="TextSecondary">#FF9CA3AF</Color>
    <Color x:Key="TextOnLight">#FF1A1D21</Color>
    <Color x:Key="BorderColor">#FF3B4048</Color>
    <Color x:Key="ErrorHighlight">#FF4A2C2C</Color>

    <SolidColorBrush x:Key="ErrorHighlightBrush" Color="{StaticResource ErrorHighlight}"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="{StaticResource TextOnLight}"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDark}"/>
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="{StaticResource BackgroundMedium}"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource BackgroundLight}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <LinearGradientBrush x:Key="HomeHeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF111827" Offset="0"/>
        <GradientStop Color="#FF1E293B" Offset="0.7"/>
        <GradientStop Color="#FF273469" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="HomeHeroTitleBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="HomeHeroSubtitleBrush" Color="#FFC7D2FE"/>
    <SolidColorBrush x:Key="HomeHeroDescriptionBrush" Color="#FFCBD5E1"/>
    <SolidColorBrush x:Key="HomeHeroVisualStrokeBrush" Color="#FF22D3EE"/>
    <SolidColorBrush x:Key="HomeHeroVisualGridBrush" Color="#556366F1"/>

    <!-- Sidebar button style -->
    <Style x:Key="SidebarNavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderThickness="0,0,3,0" BorderBrush="{StaticResource AccentBrush}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarNavButtonSelected" TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
    </Style>

    <DropShadowEffect x:Key="CardShadowEffect" Color="#66000000" BlurRadius="12" ShadowDepth="2" Opacity="0.25"/>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundLightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource CardShadowEffect}"/>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BackgroundMediumBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="14,8"/>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="16,10"/>
    </Style>

</ResourceDictionary>

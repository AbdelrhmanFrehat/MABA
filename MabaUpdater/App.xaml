<Application x:Class="MabaUpdater.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#101827"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1C2533"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3C4E68"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C7BFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAB6C7"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
    </Application.Resources>
</Application>
